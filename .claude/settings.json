{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/validate-skill-on-edit.mjs",
            "timeout": 30,
            "statusMessage": "Validating skills..."
          }
        ]
      }
    ]
  }
}
